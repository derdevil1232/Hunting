{
  "schemaVersion": 1,
  "id": "hunter",
  "version": "${version}",
  "name": "Hunter",
  "description": "An addon for Meteor Client focused on hunting spawners.",
  "authors": [
    "c3"
  ],
  "contact": {
    "sources": "https://github.com/Meteor-Hunting/Hunting.git"
  },
  "icon": "assets/template/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "com.spawner.hunt.Hunters"
    ]
  },
  "accessWidener": "hunters.accesswidener",
  "custom": {
    "meteor-client:color": "225,25,25",
    "modmenu": {
      "parent": {
        "id": "meteor-client"
      }
    }
  },
  "depends": {
    "java": ">=${jdk_version}",
    "minecraft": "${minecraft_version}",
    "meteor-client": "*"
  }
}
